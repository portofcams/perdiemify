# === VULTR SERVER (.env) ===
# Copy this to .env and fill in values

# Database
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://perdiemify:${DB_PASSWORD}@postgres:5432/perdiemify

# Redis
REDIS_URL=redis://redis:6379

# Clerk Auth
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Amadeus (Travel Search)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Affiliate Partners
TRAVELPAYOUTS_API_KEY=
BOOKING_AFFILIATE_ID=
SKYSCANNER_API_KEY=
KIWI_API_KEY=

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PROPLUS_PRICE_ID=

# Resend (Email)
RESEND_API_KEY=

# Anthropic (AI Planner - Phase 5)
ANTHROPIC_API_KEY=

# Server Config
API_PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://perdiemify.com

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=perdiemify-uploads
