{
  "name": "perdiemify",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=packages/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=packages/api",
    "db:generate": "npm run db:generate --workspace=packages/api",
    "db:migrate": "npm run db:migrate --workspace=packages/api",
    "docker:dev": "docker compose -f infra/docker-compose.yml up -d",
    "docker:prod": "docker compose -f infra/docker-compose.prod.yml up -d"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
