# =============================================================================
# Perdiemify — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables marked [REQUIRED] must be set for the app to function.
# Variables marked [OPTIONAL] have working defaults or enable extra features.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CLERK — Authentication (https://dashboard.clerk.com)
# -----------------------------------------------------------------------------
# [REQUIRED] — App won't build or run without these
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# [OPTIONAL] — Only needed if you use Clerk webhooks
CLERK_WEBHOOK_SECRET=whsec_...

# [OPTIONAL] — Defaults shown; override if you change route structure
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# 2. STRIPE — Payments (https://dashboard.stripe.com)
# -----------------------------------------------------------------------------
# [REQUIRED] — Billing page and checkout won't work without these
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# [REQUIRED] — Create two products in Stripe Dashboard, paste IDs here
STRIPE_PRO_PRODUCT_ID=prod_...
STRIPE_PROPLUS_PRODUCT_ID=prod_...

# [OPTIONAL] — Auto-discovered from product if not set
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_PROPLUS_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# 3. AMADEUS — Hotel & Flight Search (https://developers.amadeus.com)
# -----------------------------------------------------------------------------
# [REQUIRED] — Search returns no results without these
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# -----------------------------------------------------------------------------
# 4. RESEND — Transactional Email (https://resend.com)
# -----------------------------------------------------------------------------
# [REQUIRED] — Waitlist signup, deal alerts, and price alerts need this
RESEND_API_KEY=re_...

# [OPTIONAL] — Defaults to Perdiemify <alerts@perdiemify.com>
# RESEND_FROM=Perdiemify <alerts@perdiemify.com>

# -----------------------------------------------------------------------------
# 5. DATABASE — PostgreSQL
# -----------------------------------------------------------------------------
# [REQUIRED] — Default works with local Docker Compose
DATABASE_URL=postgresql://perdiemify:perdiemify@localhost:5432/perdiemify

# -----------------------------------------------------------------------------
# 6. REDIS — Cache & Job Queues
# -----------------------------------------------------------------------------
# [OPTIONAL] — Default works with local Docker Compose; rate limiting falls
#              back to in-memory if Redis is unavailable
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# 7. CLOUDFLARE R2 — Receipt Image Storage
# -----------------------------------------------------------------------------
# [OPTIONAL] — Falls back to local filesystem if not set
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=perdiemify-uploads

# -----------------------------------------------------------------------------
# 8. AI — Receipt OCR (https://console.anthropic.com)
# -----------------------------------------------------------------------------
# [OPTIONAL] — Falls back to Tesseract.js (local OCR) if not set
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# 9. GSA — Per Diem Rates
# -----------------------------------------------------------------------------
# [OPTIONAL] — Works with DEMO_KEY; get a real key for higher rate limits
# GSA_API_KEY=DEMO_KEY

# -----------------------------------------------------------------------------
# 10. EXPENSE INTEGRATIONS
# -----------------------------------------------------------------------------
# [OPTIONAL] — Only needed if connecting SAP Concur
# CONCUR_CLIENT_ID=
# CONCUR_CLIENT_SECRET=
# CONCUR_REDIRECT_URI=https://perdiemify.com/api/integrations/concur/callback

# -----------------------------------------------------------------------------
# 11. AFFILIATE PARTNERS
# -----------------------------------------------------------------------------
# [OPTIONAL] — Revenue links; app works without these
# BOOKING_AFFILIATE_ID=
# SKYSCANNER_API_KEY=
# TRAVELPAYOUTS_API_KEY=
# KIWI_API_KEY=

# -----------------------------------------------------------------------------
# 12. APP CONFIGURATION
# -----------------------------------------------------------------------------
# [OPTIONAL] — Defaults shown
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=https://perdiemify.com
API_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# [OPTIONAL] — Internal API key for scraper → API communication
# INTERNAL_API_KEY=perdiemify-internal
